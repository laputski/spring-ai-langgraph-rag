# ── Compiled output ──────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.nar
*.ear

# ── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ── IntelliJ IDEA ────────────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ── VS Code ──────────────────────────────────────────────────────────────────
.vscode/

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
spring-shell.log

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.jks

# ── Docker volumes (if mounted locally) ──────────────────────────────────────
qdrant_storage/
valkey_data/

# ── Python (guardrail sidecars) ──────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# ── Claude Code ──────────────────────────────────────────────────────────────
.claude/

# ── Legacy / noise ───────────────────────────────────────────────────────────
*.ctxt
.mtj.tmp/
hs_err_pid*
replay_pid*
