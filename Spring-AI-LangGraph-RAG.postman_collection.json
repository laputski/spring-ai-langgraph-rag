					"name": "✅ Happy path — RAG answer",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"query\": \"What is Spring Boot auto-configuration?\",\n  \"sessionId\": \"session-001\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/v1/chat",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "chat"]
						},
						"description": "Ожидаемый ответ: source=RAG, cached=false, answer с объяснением Spring Boot."
					}
				},
				{
					"name": "✅ Cache hit — повторный одинаковый запрос",
